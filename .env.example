# URL del Postgres applicativo (default: il servizio di docker-compose.yml)
TRACKPROOF_DATABASE_URL=postgresql://trackproof:trackproof@localhost:5432/trackproof

# URL del Postgres dei test di integrazione (database separato, creato dai test)
TRACKPROOF_TEST_DATABASE_URL=postgresql://trackproof:trackproof@localhost:5432/trackproof_test

# Percorso esplicito del binario fpcalc di Chromaprint, se non e' nella PATH
# FPCALC=C:\percorso\di\fpcalc.exe
